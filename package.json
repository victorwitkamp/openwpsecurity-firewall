{
	"name": "openwpsecurity-firewall",
	"version": "0.3.0",
	"private": true,
	"description": "Asset build tooling for the OpenWPSecurity - Firewall plugin.",
	"scripts": {
		"build": "npm run build:css",
		"build:css": "sass assets/scss/admin.scss:assets/css/admin.css assets/scss/runtime.scss:assets/css/runtime.css --style=expanded --no-source-map",
		"watch:css": "sass --watch assets/scss/admin.scss:assets/css/admin.css assets/scss/runtime.scss:assets/css/runtime.css --style=expanded --no-source-map",
		"lint:php": "composer lint"
	},
	"devDependencies": {
		"sass": "^1.101.0"
	}
}
